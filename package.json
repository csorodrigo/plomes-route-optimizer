{
  "name": "sales-route-optimizer",
  "version": "1.0.0",
  "description": "Sistema de otimização de rotas comerciais com integração Ploome",
  "main": "backend/server.js",
  "scripts": {
    "setup": "node setup.js",
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "node backend/server.js",
    "build": "cd frontend && npm run build",
    "sync:ploome": "node backend/services/sync/sync-customers.js",
    "test:connection": "curl http://localhost:3001/api/test-connection"
  },
  "keywords": [
    "route",
    "optimization",
    "ploome",
    "crm",
    "sales"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "haversine-distance": "^1.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.2",
    "p-limit": "^3.1.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
