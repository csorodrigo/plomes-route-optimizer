{
  "name": "plomes-rota-cep-v2-fixed",
  "version": "2.1.4-pt-br",
  "description": "Sistema de otimização de rotas Ploome - Integração completa com API Ploome",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node backend/server.js",
    "backend": "node backend/server.js",
    "frontend": "cd frontend && npm start",
    "build": "npm run install-frontend && npm run build-frontend",
    "build-frontend": "cd frontend && npm run build",
    "install-frontend": "cd frontend && npm ci",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install-all": "npm install && cd frontend && npm install",
    "test": "echo \"Error: no test specified\" && exit 1",
    "railway-build": "npm run install-frontend && npm run build-frontend && echo 'Build completed successfully'",
    "railway-start": "node backend/server.js"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.2.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "decode-uri-component": "^0.2.2",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "haversine-distance": "^1.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemon": "^3.0.2",
    "p-limit": "^3.1.0",
    "polyline": "^0.2.0",
    "split-on-first": "^1.0.0",
    "sqlite3": "^5.1.6",
    "strict-uri-encode": "^2.0.0"
  },
  "keywords": [
    "ploome",
    "routes",
    "optimization",
    "crm",
    "geocoding",
    "api"
  ],
  "author": "Sistema Ploome",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/plomes-rota-cep.git"
  }
}
